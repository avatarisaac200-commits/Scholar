rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function roleOf(uid) {
      return userDoc(uid).data.role;
    }

    function isAdmin() {
      return signedIn() && (roleOf(request.auth.uid) == 'admin' || roleOf(request.auth.uid) == 'root-admin');
    }

    function isRootAdmin() {
      return signedIn() && roleOf(request.auth.uid) == 'root-admin';
    }

    function hasOnly(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function isValidPercent(value) {
      return value is number && value >= 0 && value <= 100;
    }

    function validTestLeaderboardPublicRow() {
      return hasOnly([
          'userId',
          'userName',
          'testId',
          'testName',
          'score',
          'maxScore',
          'scorePercent',
          'completedAt',
          'status'
        ]) &&
        request.resource.data.keys().hasAll([
          'userId',
          'userName',
          'testId',
          'testName',
          'score',
          'maxScore',
          'scorePercent',
          'completedAt',
          'status'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userId is string &&
        request.resource.data.userName is string &&
        request.resource.data.testId is string &&
        request.resource.data.testName is string &&
        request.resource.data.score is number &&
        request.resource.data.maxScore is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.maxScore >= 0 &&
        isValidPercent(request.resource.data.scorePercent) &&
        request.resource.data.completedAt is string &&
        request.resource.data.status in ['completed', 'abandoned', 'auto-submitted'];
    }

    function validOwnLeaderboardPublicRow(rowId) {
      return rowId == request.auth.uid &&
        hasOnly([
          'userId',
          'userName',
          'attempts',
          'averagePercent',
          'bestPercent',
          'lastCompletedAt',
          'sortKey',
          'updatedAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'userId',
          'userName',
          'attempts',
          'averagePercent',
          'bestPercent',
          'lastCompletedAt',
          'sortKey',
          'updatedAt'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userId is string &&
        request.resource.data.userName is string &&
        request.resource.data.attempts is number &&
        request.resource.data.attempts >= 1 &&
        request.resource.data.attempts <= 1000 &&
        isValidPercent(request.resource.data.averagePercent) &&
        isValidPercent(request.resource.data.bestPercent) &&
        request.resource.data.lastCompletedAt is string &&
        request.resource.data.sortKey is string &&
        request.resource.data.updatedAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isRootAdmin();

      allow create: if
        isOwner(userId) &&
        request.resource.data.id == userId &&
        request.resource.data.role == 'student';

      allow create, update, delete: if isRootAdmin();

      allow update: if
        isOwner(userId) &&
        request.resource.data.id == userId &&
        (resource.data.id == null || request.resource.data.id == resource.data.id) &&
        (resource.data.email == null || request.resource.data.email == resource.data.email) &&
        (resource.data.role == null || request.resource.data.role == resource.data.role);
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /tests/{testId} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /results/{resultId} {
      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow get: if
        signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.userId == request.auth.uid
        );

      allow update, delete: if isAdmin();
    }

    match /leaderboardPublic/{rowId} {
      allow get, list: if signedIn();
      allow create, update: if isAdmin() || (signedIn() && validOwnLeaderboardPublicRow(rowId));
      allow delete: if isAdmin();
    }

    match /testLeaderboardPublic/{rowId} {
      allow get, list: if signedIn();
      allow create: if
        isAdmin() ||
        (signedIn() && validTestLeaderboardPublicRow());
      allow update: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid && validTestLeaderboardPublicRow());
      allow delete: if isAdmin();
    }

    match /testAttempts/{attemptId} {
      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow get: if
        signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if
        signedIn() &&
        (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow get: if signedIn();
      allow list: if signedIn();

      allow create: if
        signedIn() &&
        request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if
        signedIn() &&
        (
          resource.data.createdBy == request.auth.uid ||
          isAdmin()
        );
    }

    match /courses/{courseId} {
      allow get, list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.isPublished == true
        );
      allow create, update, delete: if isAdmin();
    }

    match /courseSessions/{sessionId} {
      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow get, list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.userId == request.auth.uid
        );

      allow update, delete: if isAdmin();
    }

    match /courseEnrollmentsPublic/{enrollmentId} {
      allow get, list: if signedIn();

      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userId is string &&
        request.resource.data.courseId is string &&
        (!('userName' in request.resource.data) || request.resource.data.userName is string) &&
        request.resource.data.createdAt is string &&
        enrollmentId == (request.resource.data.courseId + '_' + request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /videoLessons/{lessonId} {
      allow get, list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.isPublished == true
        );

      allow create, update, delete: if isAdmin();
    }

    match /videoProgress/{progressId} {
      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        progressId == (request.auth.uid + '_' + request.resource.data.lessonId);

      allow get, list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.userId == request.auth.uid
        );

      allow update: if
        signedIn() &&
        (
          isAdmin() ||
          (
            resource.data.userId == request.auth.uid &&
            request.resource.data.userId == request.auth.uid
          )
        );

      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if signedIn();
      allow create: if signedIn() && isAdmin() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if signedIn() && isAdmin();
    }

    match /announcementReads/{readId} {
      allow get, list: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /classSessions/{sessionId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get, list: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && isAdmin() && request.resource.data.userId is string;
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /notificationPreferences/{preferenceId} {
      allow get, list: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /pushSubscriptions/{subscriptionId} {
      allow get, list: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /licenseKeys/{keyId} {
      allow get: if signedIn();
      allow list: if isRootAdmin();
      allow create, update, delete: if isRootAdmin();
      allow update: if
        signedIn() &&
        resource.data.status == 'new' &&
        resource.data.isUsed == false &&
        request.resource.data.status == 'used' &&
        request.resource.data.isUsed == true &&
        request.resource.data.redeemedBy == request.auth.uid &&
        request.resource.data.redeemedByEmail is string &&
        request.resource.data.redeemedAt is string &&
        request.resource.data.code == resource.data.code &&
        request.resource.data.prepMode == resource.data.prepMode &&
        request.resource.data.durationDays == resource.data.durationDays &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdByName == resource.data.createdByName &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    match /questionTagInsights/{tagId} {
      allow create: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow get, list: if
        signedIn() &&
        (
          isAdmin() ||
          resource.data.userId == request.auth.uid
        );

      allow update, delete: if isAdmin();
    }

    match /broadcastNotifications/{notificationId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /forumThreads/{threadId} {
      allow get, list: if signedIn();

      allow create: if
        signedIn() &&
        request.resource.data.authorId == request.auth.uid;

      allow update, delete: if
        signedIn() &&
        (
          resource.data.authorId == request.auth.uid ||
          isAdmin()
        );

      match /replies/{replyId} {
        allow get, list: if signedIn();

        allow create: if
          signedIn() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.threadId == threadId;

        allow update, delete: if
          signedIn() &&
          (
            resource.data.authorId == request.auth.uid ||
            isAdmin()
          );
      }
    }

    match /directConversations/{conversationId} {
      allow get, list: if
        signedIn() &&
        resource.data.participantIds.hasAny([request.auth.uid]);

      allow create: if
        signedIn() &&
        request.resource.data.participantIds is list &&
        request.resource.data.participantIds.size() == 2 &&
        request.resource.data.participantIds.hasAny([request.auth.uid]);

      allow update, delete: if
        signedIn() &&
        resource.data.participantIds.hasAny([request.auth.uid]);

      match /messages/{messageId} {
        allow get, list: if
          signedIn() &&
          get(/databases/$(database)/documents/directConversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);

        allow create: if
          signedIn() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.conversationId == conversationId &&
          get(/databases/$(database)/documents/directConversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);

        allow update, delete: if
          signedIn() &&
          resource.data.authorId == request.auth.uid;
      }
    }

    match /communityProfiles/{profileId} {
      allow get, list: if signedIn();

      allow create, update: if
        signedIn() &&
        (
          request.auth.uid == profileId ||
          isAdmin()
        ) &&
        request.resource.data.userId == profileId;

      allow delete: if request.auth.uid == profileId || isAdmin();
    }

    match /friendRequests/{requestId} {
      allow get, list: if
        signedIn() &&
        (
          resource.data.senderId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid ||
          isAdmin()
        );

      allow create: if
        signedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderId != request.resource.data.recipientId;

      allow update, delete: if
        signedIn() &&
        (
          resource.data.senderId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid ||
          isAdmin()
        );
    }

    match /friendships/{friendshipId} {
      allow get, list: if
        signedIn() &&
        resource.data.memberIds.hasAny([request.auth.uid]);

      allow create, update, delete: if
        signedIn() &&
        (
          request.resource.data.memberIds.hasAny([request.auth.uid]) ||
          resource.data.memberIds.hasAny([request.auth.uid]) ||
          isAdmin()
        );
    }

    match /brainstormMembers/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if
        (isOwner(userId) || isAdmin()) &&
        request.resource.data.userId == request.auth.uid;

      allow update: if
        isAdmin() ||
        (
          isOwner(userId) &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.strikeCount >= resource.data.strikeCount &&
          (
            resource.data.blacklisted == true
            ? request.resource.data.blacklisted == true
            : true
          )
        );

      allow delete: if isAdmin();
    }

    match /brainstormCheckins/{checkinId} {
      allow get: if
        signedIn() &&
        (
          isAdmin() ||
          resource == null ||
          resource.data.userId == request.auth.uid
        );

      allow list: if isAdmin();

      allow create, update: if
        signedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if isAdmin();
    }

    match /brainstormBlacklist/{userId} {
      allow get, list: if true;

      allow create: if
        isOwner(userId) &&
        request.resource.data.userId == request.auth.uid;

      allow update: if
        isOwner(userId) &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.strikeCount >= resource.data.strikeCount;

      allow delete: if isAdmin();
    }

    match /brainstormConfig/{configId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /aiQuestionExplanations/{cacheId} {
      allow read: if signedIn();

      allow create, update: if
        signedIn() &&
        hasOnly(['cacheKey', 'questionId', 'questionSignature', 'explanation', 'model', 'updatedAt']) &&
        request.resource.data.questionId is string &&
        request.resource.data.questionSignature is string &&
        request.resource.data.explanation is string &&
        request.resource.data.model is string &&
        request.resource.data.updatedAt is string;

      allow delete: if isAdmin();
    }
  }
}
